:root {
  --bg: #fff;
  --fg: #000;
  --border: 3px solid #000;
  --font: "Helvetica Neue", Helvetica, Arial, sans-serif;
}

* {
  box-sizing: border-box;
}

body {
  background: var(--bg);
  color: var(--fg);
  font-family: var(--font);
  margin: 0;
  padding: 0;
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;
}

.container {
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem;
}

header {
  margin-bottom: 3rem;
}

h1 {
  font-size: 3.5rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: -0.03em;
  margin: 0 0 1rem 0;
  border-bottom: var(--border);
  padding-bottom: 1rem;
  line-height: 1;
}

h2 {
  font-size: 2rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: -0.02em;
  margin: 0 0 2rem 0;
}

.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 1rem;
}

.nav-actions {
  display: flex;
  gap: 1rem;
  margin-left: auto;
}

.profile-badge {
  font-size: 1.25rem;
  font-weight: 400;
  vertical-align: middle;
  text-transform: none;
  letter-spacing: normal;
  opacity: 0.6;
}

button {
  background: var(--bg);
  color: var(--fg);
  border: var(--border);
  padding: 0.75rem 1.5rem;
  font-family: inherit;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.1s ease;
  letter-spacing: 0.05em;
}

button:hover, button:focus {
  background: var(--fg);
  color: var(--bg);
  outline: none;
}

.grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 600px) {
  .grid {
    grid-template-columns: 1fr 1fr;
  }
}

.card {
  border: var(--border);
  padding: 1.5rem;
  cursor: pointer;
  text-transform: uppercase;
  font-weight: 700;
  font-size: 1.25rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  text-align: left;
  width: 100%;
}

.card:hover, .card:focus, .card.active-profile {
  background: var(--fg);
  color: var(--bg);
  outline: none;
}

.form-group {
  margin-bottom: 2rem;
}

label {
  display: block;
  font-weight: 700;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
  font-size: 0.875rem;
  letter-spacing: 0.05em;
}

input {
  border: var(--border);
  padding: 1rem;
  font-family: inherit;
  font-size: 1.25rem;
  font-weight: 700;
  background: var(--bg);
  color: var(--fg);
  width: 100%;
  border-radius: 0;
  appearance: none;
}

input:focus {
  outline: 4px solid var(--fg);
  outline-offset: 2px;
}

.table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 2rem;
}

.table th, .table td {
  border-bottom: 2px solid #000;
  padding: 1rem 0;
  text-align: left;
  font-weight: 700;
  text-transform: uppercase;
}

.table th {
  font-size: 1rem;
  letter-spacing: 0.05em;
}

.table td:last-child, .table th:last-child {
  text-align: right;
}

.table tfoot th {
  border-bottom: none;
  border-top: var(--border);
}

.btn-primary {
  background: var(--fg);
  color: var(--bg);
}

.btn-primary:hover, .btn-primary:focus {
  background: var(--bg);
  color: var(--fg);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal.hidden {
  display: none !important;
}

.modal-content {
  background: var(--bg);
  padding: 2rem;
  border: var(--border);
  width: 90%;
  max-width: 500px;
}

.no-scroll-modal {
  overflow: hidden;
}

.hidden { display: none !important; }
.mb-8 { margin-bottom: 2rem; }
.mt-8 { margin-top: 2rem; }
.pt-4 { padding-top: 1rem; }
.border-t { border-top: var(--border); }
.text-xl { font-size: 1.5rem; }
.text-2xl { font-size: 2.5rem; }
